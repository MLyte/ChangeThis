{
  "name": "@changethis/widget",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/widget.global.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && npm run size:check && tsc -p tsconfig.json --emitDeclarationOnly",
