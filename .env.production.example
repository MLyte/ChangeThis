# ChangeThis production environment example
# No secrets: replace every value marked as required before deploying.

# App
NEXT_PUBLIC_APP_URL=https://app.example.com
AUTH_MODE=supabase
DATA_STORE=supabase
CHANGETHIS_SECRET_KEY=
ENABLE_PUBLIC_SIGNUP=false

# Optional override for filesystem storage in non-container/local fallback
CHANGETHIS_DATA_DIR=

# Public project keys used by widget embeds (configure matching production domains).
NEXT_PUBLIC_DEMO_PROJECT_KEY=demo_project_key
NEXT_PUBLIC_CHANGETHIS_PROJECT_KEY=
NEXT_PUBLIC_ANDENNE_BEARS_PROJECT_KEY=
NEXT_PUBLIC_OPTIMASTER_PROJECT_KEY=
NEXT_PUBLIC_YODA_CARROSSERIE_PROJECT_KEY=

# Supabase (required si DATA_STORE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub provider (app or token flow)
GITHUB_PROVIDER_INTEGRATION_ID=
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
CHANGETHIS_GITHUB_TOKEN=

# GitLab provider (OAuth or token flow)
GITLAB_PROVIDER_INTEGRATION_ID=
GITLAB_BASE_URL=
GITLAB_OAUTH_APP_ID=
GITLAB_OAUTH_APP_SECRET=
GITLAB_WEBHOOK_SECRET=
GITLAB_TOKEN=
CHANGETHIS_GITLAB_TOKEN=
