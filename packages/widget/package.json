    "size:check": "node ../../scripts/check-widget-bundle-size.mjs",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@changethis/shared": "0.1.0",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
